{
  "name": "@ow/server",
  "private": true,
  "scripts": {
    "dev": "npx tsx watch --include=./src/**/* --env-file=.env src/server.ts",
    "db:browse": "npx drizzle-kit studio",
    "db:reset": "npm run db:remake && npm run db:push && npm run db:seed",
    "db:remake": "npx tsx ./scripts/remake.ts",
    "db:seed": "npx tsx ./scripts/seed.ts",
    "db:truncate": "npx tsx ./scripts/truncate.ts",
    "db:push": "npx drizzle-kit push"
  },
  "dependencies": {
    "@orpc/server": "^1.13.6",
    "@oslojs/crypto": "^1.0.1",
    "@oslojs/encoding": "^1.1.0",
    "@ow/shared": "*",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.2.2",
    "@types/ws": "^8.18.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "date-fns": "^4.1.0",
    "drizzle-kit": "^0.18.1",
    "drizzle-orm": "^0.45.1",
    "express": "^5.2.1",
    "mysql2": "^3.19.0",
    "vitest": "^4.0.18",
    "ws": "^8.19.0",
    "zod": "^4.3.6"
  }
}
